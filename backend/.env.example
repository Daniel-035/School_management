# Local HTTP port used by the Express API.
PORT=8080

# Runtime mode: development, test, or production.
NODE_ENV=development

# Google Cloud project containing the application's Firestore database.
FIRESTORE_PROJECT_ID=your-firebase-project-id

# Firebase Web API key (project Settings -> General -> Web apps).
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# Minified Firebase Admin service-account JSON (local only — Cloud Functions use ADC in production).
# Leave empty when running against the Firestore emulator.
FIREBASE_SERVICE_ACCOUNT=

# Default Cloud Storage bucket for uploads.
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Application identity used in credential emails and links.
APP_NAME=EduConnect
APP_BASE_URL=http://localhost:5173

# SMTP transport for emailing generated login credentials to new users.
# Optional: leave blank to return credentials to the admin console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Comma-separated browser origins permitted by CORS.
CORS_ORIGINS=http://localhost:5173,http://localhost:5000,http://localhost:5001

# Authentication endpoint rate limit.
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# Set to true only when demo records should be inserted at startup. Keep false in production.
SEED_DEMO_DATA=false

# Bootstrap administrator credentials used by the seed script only.
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=your-strong-admin-password

# JWT (kept for backward compatibility — Firebase Auth is the primary auth provider).
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=30
BCRYPT_ROUNDS=12
