# Local HTTP port used by the Express API.
PORT=8080

# Runtime mode: development, test, or production.
NODE_ENV=development

# Google Cloud project containing the application's Firestore database.
FIRESTORE_PROJECT_ID=schoolmanagement-23f78

# Firebase Web API key (project Settings -> General -> Web apps). Used by the
# backend to verify sign-in via Firebase Authentication, which is the sole login method.
FIREBASE_WEB_API_KEY=replace-with-firebase-web-api-key

# Minified Firebase Admin service-account JSON. Keep the real value only in
# backend/.env locally or in the deployment platform's secret manager.
FIREBASE_SERVICE_ACCOUNT={"project_id":"schoolmanagement-23f78","client_email":"firebase-adminsdk-fbsvc@schoolmanagement-23f78.iam.gserviceaccount.com","private_key":"replace-with-private-key"}

# Default Cloud Storage bucket for uploads.
FIREBASE_STORAGE_BUCKET=schoolmanagement-23f78.appspot.com

# Application identity used in credential emails and links.
APP_NAME=EduConnect
APP_BASE_URL=http://localhost:5173

# SMTP transport for emailing generated login credentials to new users.
# Optional in development: when SMTP_HOST is unset, generated credentials are
# returned to the administrator instead of being emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Comma-separated browser origins permitted by CORS.
CORS_ORIGINS=http://localhost:5173

# Authentication endpoint rate limit.
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# Seed demo users and school records at startup (creates real Firebase Auth
# users with generated passwords, logged to the console). Keep false in production.
SEED_DEMO_DATA=false

# Bootstrap administrator credentials used only by the demo seed. The admin is
# created as a Firebase Auth user with this password; change it in production.
ADMIN_EMAIL=admin@school.local
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# ---- Deprecated (kept only for backward compatibility; Firebase Auth is now the
# ---- sole authentication provider and these are no longer used by the auth flow).
JWT_SECRET=replace-with-a-long-random-secret-value
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=30
BCRYPT_ROUNDS=12
