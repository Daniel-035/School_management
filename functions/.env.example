# Firebase Functions local environment
# Copy this to .env for local development.
# DO NOT commit .env — it is git-ignored.

FIRESTORE_PROJECT_ID=your-firebase-project-id
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

APP_NAME=EduConnect
APP_BASE_URL=http://localhost:5000

CORS_ORIGINS=http://localhost:5173,http://localhost:5000

# Leave blank locally — Cloud Functions use Application Default Credentials
FIREBASE_SERVICE_ACCOUNT=

# Bootstrap admin (only used if SEED_DEMO_DATA=true)
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=your-strong-admin-password
SEED_DEMO_DATA=false

# SMTP (optional — omit to return credentials to console instead of emailing)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# JWT (legacy — kept for backward compat)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=15m
